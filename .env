# Fork environment defaults (public endpoints, NOT secrets).
# In accountless mode only the anonymous API and the external-resources CDN are
# used; account/login-only vars (AUTH, WS, CHECKOUT, LAUNCHER_SUBDOMAIN) are
# intentionally left empty and their consumers degrade gracefully.

# Anonymous Hydra API (catalogue, download sources, achievements) - verified.
MAIN_VITE_API_URL=https://hydra-api-us-east-1.losbroxas.org

# Public CDN serving game-executables.json, steam-*.json and theme bundle.js.
MAIN_VITE_EXTERNAL_RESOURCES_URL=https://assets.hydralauncher.gg
RENDERER_VITE_EXTERNAL_RESOURCES_URL=https://assets.hydralauncher.gg

# Account / login-only - unused in accountless mode.
MAIN_VITE_AUTH_URL=
MAIN_VITE_WS_URL=
MAIN_VITE_CHECKOUT_URL=
MAIN_VITE_LAUNCHER_SUBDOMAIN=

# Hoster unlock (VikingFile) - no public endpoint wired; feature fails gracefully.
MAIN_VITE_NIMBUS_API_URL=

# Referral IDs - intentionally empty.
RENDERER_VITE_REAL_DEBRID_REFERRAL_ID=
RENDERER_VITE_TORBOX_REFERRAL_CODE=
